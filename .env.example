# Google Service Account Credentials
# Lấy từ Google Cloud Console > IAM & Admin > Service Accounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Private key từ service account JSON file
# Lưu ý: Giữ nguyên format với \n cho line breaks
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"

# Google Sheets Configuration
# Spreadsheet ID từ URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SPREADSHEET_ID=1bn9mGEME4gb5wUNZ0riAgvbwn65gvJvKNJyz8BFxOxw

# Sheet ID (gid) từ URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit?gid={SHEET_ID}
GOOGLE_SHEET_ID=1685564899
